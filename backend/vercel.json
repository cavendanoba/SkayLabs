{
  "buildCommand": "echo 'Serverless functions ready for deployment'",
  "public": false,
  "functions": {
    "api/discordia/admin-login.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/discordia/products.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/discordia/payments.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/discordia/dashboard.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/discordia/sales.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/discordia/discordia-data.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/copcash/[...slug].js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/health.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "env": {
    "DATABASE_URL": "@database_url"
  }
}
